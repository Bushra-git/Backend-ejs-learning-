<%- include("includes/head.ejs") %>
<body>
    
    <h1>Welcome to Instagram, <%= data.name %>!</h1>
    <button>follow  <%= data.name %></button>
    <button>Message <%= data.name %></button>
    <p> followers : <%= data.followers %>   &nbsp; &nbsp; following :   <%= data.following %>
         </p>
         <hr>
         <h2> Post of <%= data.name %></h2>
         
         
     <% for(let post of data.posts){ %>
<img src = "  <%= post.image %> " alt = "post image" />

 <p> Likes : <%= post.likes %>  Comments : <%= post.comments %></p>
<%}%>
</body>
<script src="/js/app.js"></script>
</html>

